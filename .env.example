# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/zenvora_mart_bd

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=zenvora_token

# Admin bootstrap (used by scripts/seed.js)
ADMIN_EMAIL=admin@zenvoramart.com
ADMIN_PASSWORD=ChangeMe123!

# Store contact
NEXT_PUBLIC_WHATSAPP_NUMBER=8801754222891
NEXT_PUBLIC_ORDER_PHONE=01754222891

# Payments (manual verification numbers shown in checkout UI)
NEXT_PUBLIC_BKASH_NUMBER=01754222891
NEXT_PUBLIC_NAGAD_NUMBER=01754222891

# Email (Nodemailer SMTP) - order confirmation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Zenvora Mart BD <no-reply@zenvoramart.com>"

# SMS Gateway (e.g. BulkSMSBD) - order confirmation SMS
SMS_API_URL=https://bulksmsbd.net/api/smsapi
SMS_API_KEY=your_api_key
SMS_SENDER_ID=your_sender_id

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=000000000000000

NEXT_PUBLIC_SITE_URL=http://localhost:3000
